# qBittorrent connection
# Full URL to the qBittorrent WebUI (e.g. https://your-seedbox.example.com:8080)
QBITTORRENT_URL=http://localhost:8080
# Username for qBittorrent WebUI authentication
QBITTORRENT_USERNAME=admin
# Password for qBittorrent WebUI authentication
QBITTORRENT_PASSWORD=adminadmin
# Timeout in milliseconds for each qBittorrent Web API request
QBITTORRENT_REQUEST_TIMEOUT_MS=30000

# Logging
# Log verbosity for application, MCP, and qBittorrent operation logs (debug, info, warn, error)
LOG_LEVEL=info
# Log layout: pretty (default; readable lines and indented meta) or json (one JSON object per line for aggregators)
# LOG_FORMAT=json
# Include /api/health and /api/ready in HTTP access logs (default: omit; Docker healthchecks otherwise add noise next to MCP lines)
# LOG_ACCESS_LOG_PROBES=true

# Server
# Port the API listens on
PORT=7100

# Rate limiting (main)
# Time window in milliseconds for the main rate limit
RATE_LIMIT_WINDOW_MS=900000
# Maximum number of requests allowed per window
RATE_LIMIT_MAX=100

# Rate limiting (health check)
# Time window in milliseconds for the /api/health rate limit
HEALTH_RATE_LIMIT_WINDOW_MS=500
# Maximum number of health check requests allowed per window
HEALTH_RATE_LIMIT_MAX=1
